generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(64)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  hiddenNetworks UserHiddenNetwork[]

  @@map("admin_users")
}

model UserHiddenNetwork {
  userId       Int    @map("user_id")
  controllerId Int    @map("controller_id")
  networkId    String @map("network_id") @db.VarChar(32)
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, controllerId, networkId])
  @@map("user_hidden_networks")
}

model Controller {
  id                   Int       @id @default(autoincrement())
  name                 String    @unique @db.VarChar(100)
  region               String    @db.VarChar(32)
  baseUrl              String    @map("base_url") @db.VarChar(255)
  username             String    @db.VarChar(100)
  passwordEnc          String    @map("password_enc") @db.Text
  subnetPoolCidr       String    @map("subnet_pool_cidr") @db.VarChar(32)
  subnetPrefix         Int       @map("subnet_prefix") @default(24)
  planetFileContent    Bytes?    @map("planet_file_content") @db.MediumBlob
  planetFileSize       Int?      @map("planet_file_size")
  planetFileUploadedAt DateTime? @map("planet_file_uploaded_at")
  status               String    @default("unknown") @db.VarChar(16)
  lastCheckedAt        DateTime? @map("last_checked_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@map("controllers")
}
