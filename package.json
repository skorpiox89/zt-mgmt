{
  "name": "zt-mgmt",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "core-js",
      "prisma"
    ]
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev:server": "pnpm --filter @zt-mgmt/server start:dev",
    "dev:web": "pnpm --filter @zt-mgmt/web dev",
    "lint": "pnpm -r lint"
  }
}
