# Copy this file to .env.production and replace every placeholder before deployment.
# Keep the completed file beside the Makefile on the customer host.

MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password
MYSQL_DATABASE=zt_mgmt
MYSQL_USER=zt_mgmt
MYSQL_PASSWORD=replace-with-a-strong-database-password

# Use long, independent random values. These values protect login sessions and
# encrypted controller credentials respectively, so do not rotate them after
# the service has stored data unless a migration plan is in place.
JWT_SECRET=replace-with-a-long-random-jwt-secret
CONTROLLER_PASSWORD_KEY=replace-with-a-long-random-controller-key

# Host ports exposed by the complete Docker Compose stack.
MYSQL_PORT=19075
SERVER_PORT=19070
WEB_PORT=19071

# Optional comma-separated customer domains accepted by the Web service.
# IP-address access works without this setting.
VITE_ALLOWED_HOSTS=
